<!DOCTYPE html>
<html>
<head>
    <title>Book Train - Railway Reservation</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="/css/app.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-inverse glass-navbar">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#main-nav">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <a class="navbar-brand" href="/"><i class="fas fa-train"></i> Railway Reservation</a>
            </div>
            <div class="collapse navbar-collapse" id="main-nav">
                <ul class="nav navbar-nav">
                    <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
                    <li><a href="/helpline"><i class="fas fa-phone-alt"></i> Helpline</a></li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container section-wrapper">
        <!-- Train Info Header -->
        <div class="glass-panel animate-in" style="text-align: center; margin-bottom: 30px;">
            <p style="color: rgba(255,255,255,0.5); font-size: 12px; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 5px;">Selected Train</p>
            <h3 style="margin: 0 0 5px 0; font-weight: 300; color: rgba(255,255,255,0.9);">
                <span style="color: #4facfe; font-weight: 600;"><%= train.source %></span>
                <i class="fas fa-long-arrow-alt-right" style="margin: 0 15px; color: rgba(255,255,255,0.3);"></i>
                <span style="color: #4facfe; font-weight: 600;"><%= train.destination %></span>
            </h3>
            <div style="margin-top: 10px; display: flex; gap: 25px; justify-content: center; flex-wrap: wrap;">
                <span style="color: rgba(255,255,255,0.6); font-size: 14px;"><i class="far fa-calendar-alt" style="color: #00f2fe;"></i> <%= date %></span>
                <span style="color: rgba(255,255,255,0.6); font-size: 14px;"><i class="fas fa-ticket-alt" style="color: #00f2fe;"></i> <%= classs %></span>
                <span style="color: rgba(255,255,255,0.6); font-size: 14px;"><i class="fas fa-rupee-sign" style="color: #00f2fe;"></i> <%= price %></span>
            </div>
        </div>

        <h2 class="page-title animate-in"><i class="fas fa-user-edit"></i> Passenger Details</h2>
        <p class="page-subtitle">Fill in passenger information to proceed with booking</p>

        <div class="row">
            <div class="col-md-8 col-md-offset-2">
                <div class="glass-panel animate-in">
                    <form action="/train/payment" method="POST">
                        <!-- Hidden fields -->
                        <input type="hidden" name="train_id" value="<%= train._id %>">
                        <input type="hidden" name="price" value="<%= price %>">
                        <input type="hidden" name="date" value="<%= date %>">
                        <input type="hidden" name="classs" value="<%= classs %>">
                        <input type="hidden" name="source" value="<%= train.source %>">
                        <input type="hidden" name="destination" value="<%= train.destination %>">

                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label><i class="fas fa-user"></i> Full Name</label>
                                    <input type="text" name="person1[name]" class="form-control glass-input" placeholder="Enter passenger name" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label><i class="fas fa-birthday-cake"></i> Age</label>
                                    <input type="number" name="person1[age]" class="form-control glass-input" placeholder="Age" min="1" max="120" required>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-venus-mars"></i> Gender</label>
                            <select name="person1[sex]" class="form-control glass-input">
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                                <option value="others">Others</option>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-envelope"></i> Email</label>
                                    <input type="email" name="person1[email]" class="form-control glass-input" placeholder="email@example.com">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-phone"></i> Phone Number</label>
                                    <input type="number" name="person1[phone]" class="form-control glass-input" placeholder="10-digit mobile number" min="1000000000" max="9999999999" required>
                                </div>
                            </div>
                        </div>

                        <hr style="margin: 25px 0;">

                        <!-- Summary -->
                        <div style="background: rgba(79,172,254,0.06); border-radius: 12px; padding: 18px; margin-bottom: 25px;">
                            <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;">
                                <div>
                                    <span style="color: rgba(255,255,255,0.5); font-size: 12px; text-transform: uppercase;">Class</span><br>
                                    <strong style="color: #4facfe;"><%= classs %></strong>
                                </div>
                                <div>
                                    <span style="color: rgba(255,255,255,0.5); font-size: 12px; text-transform: uppercase;">Date</span><br>
                                    <strong><%= date %></strong>
                                </div>
                                <div>
                                    <span style="color: rgba(255,255,255,0.5); font-size: 12px; text-transform: uppercase;">Fare</span><br>
                                    <strong style="color: #00f2fe; font-size: 18px;"><i class="fas fa-rupee-sign" style="font-size: 14px;"></i> <%= price %></strong>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn glass-btn btn-block" style="font-size: 16px; padding: 14px;">
                            <i class="fas fa-arrow-right"></i> Proceed to Payment
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="site-footer">
        <div class="container">
            <p>&copy; 2024 Railway Reservation System. All rights reserved.</p>
        </div>
    </div>

</body>
</html>
