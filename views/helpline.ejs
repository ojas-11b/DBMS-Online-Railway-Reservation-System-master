<!DOCTYPE html>
<html>
<head>
    <title>Helpline - Railway Reservation</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="/css/app.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-inverse glass-navbar">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#main-nav">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <a class="navbar-brand" href="/"><i class="fas fa-train"></i> Railway Reservation</a>
            </div>
            <div class="collapse navbar-collapse" id="main-nav">
                <ul class="nav navbar-nav">
                    <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
                    <li class="active"><a href="/helpline"><i class="fas fa-phone-alt"></i> Helpline</a></li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    <li><a href="/register"><i class="fas fa-user-plus"></i> Signup</a></li>
                    <li><a href="/login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
                    <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container section-wrapper">
        <!-- Header -->
        <div style="text-align: center; margin-bottom: 40px;" class="animate-in">
            <div style="width: 80px; height: 80px; background: rgba(79,172,254,0.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                <i class="fas fa-headset" style="font-size: 36px; color: #4facfe;"></i>
            </div>
            <h2 class="page-title" style="margin-bottom: 5px;">Customer Support</h2>
            <p style="color: rgba(255,255,255,0.6); max-width: 500px; margin: 0 auto;">We're here to help! Reach out to us through any of the channels below.</p>
        </div>

        <!-- Contact Cards -->
        <div class="row" style="margin-bottom: 40px;">
            <div class="col-md-4">
                <div class="contact-card animate-in">
                    <div class="icon phone">
                        <i class="fas fa-phone-alt"></i>
                    </div>
                    <h4 style="font-weight: 600; margin-bottom: 8px;">Phone Support</h4>
                    <p style="color: rgba(255,255,255,0.5); font-size: 13px; margin-bottom: 15px;">Available 24/7 for your queries</p>
                    <p style="color: #4facfe; font-weight: 600; font-size: 16px; margin: 0;">(+91) 8789632518</p>
                    <p style="color: rgba(255,255,255,0.6); font-size: 14px; margin-top: 5px;">(+91) 8794152330</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="contact-card animate-in" style="animation-delay: 0.1s;">
                    <div class="icon email">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <h4 style="font-weight: 600; margin-bottom: 8px;">Email Us</h4>
                    <p style="color: rgba(255,255,255,0.5); font-size: 13px; margin-bottom: 15px;">Get a response within 24 hours</p>
                    <p style="color: #00f2fe; font-weight: 500; margin: 0;">support@railreservation.com</p>
                    <p style="color: rgba(255,255,255,0.6); font-size: 14px; margin-top: 5px;">help@railreservation.com</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="contact-card animate-in" style="animation-delay: 0.2s;">
                    <div class="icon support">
                        <i class="fas fa-comments"></i>
                    </div>
                    <h4 style="font-weight: 600; margin-bottom: 8px;">Live Chat</h4>
                    <p style="color: rgba(255,255,255,0.5); font-size: 13px; margin-bottom: 15px;">Chat with our support team</p>
                    <p style="color: #38ef7d; font-weight: 500; margin: 0;">Available 8AM - 10PM IST</p>
                    <p style="color: rgba(255,255,255,0.6); font-size: 14px; margin-top: 5px;">Mon - Sat</p>
                </div>
            </div>
        </div>

        <!-- Info Panel -->
        <div class="row">
            <div class="col-md-8 col-md-offset-2">
                <div class="glass-panel animate-in">
                    <h3 style="font-weight: 600; margin-bottom: 20px; text-align: center;">
                        <i class="fas fa-info-circle" style="color: #4facfe;"></i> Important Information
                    </h3>
                    
                    <div class="info-row">
                        <div><span class="info-label"><i class="fas fa-clock" style="color: #4facfe;"></i> Booking Hours</span></div>
                        <div><span class="info-value">24/7 Online Booking Available</span></div>
                    </div>
                    <div class="info-row">
                        <div><span class="info-label"><i class="fas fa-ban" style="color: #ff6b6b;"></i> Cancellation</span></div>
                        <div><span class="info-value">Up to 4 hours before departure</span></div>
                    </div>
                    <div class="info-row">
                        <div><span class="info-label"><i class="fas fa-undo" style="color: #38ef7d;"></i> Refund Policy</span></div>
                        <div><span class="info-value">30% refund on cancellation</span></div>
                    </div>
                    <div class="info-row" style="border-bottom: none;">
                        <div><span class="info-label"><i class="fas fa-ticket-alt" style="color: #f093fb;"></i> Tatkal Booking</span></div>
                        <div><span class="info-value">Opens at 10:00 AM, 2 days prior</span></div>
                    </div>
                </div>
            </div>
        </div>

        <div style="text-align: center; margin-top: 30px;">
            <a href="/" class="btn glass-btn"><i class="fas fa-home"></i> Back to Home</a>
        </div>
    </div>

    <!-- Footer -->
    <div class="site-footer">
        <div class="container">
            <p>&copy; 2024 Railway Reservation System. All rights reserved.</p>
        </div>
    </div>

</body>
</html>