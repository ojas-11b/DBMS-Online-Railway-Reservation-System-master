<!DOCTYPE html>
<html>
<head>
    <title>Train List - Railway Reservation</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="/css/app.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-inverse glass-navbar">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#main-nav">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <a class="navbar-brand" href="/"><i class="fas fa-train"></i> Railway Reservation</a>
            </div>
            <div class="collapse navbar-collapse" id="main-nav">
                <ul class="nav navbar-nav">
                    <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
                    <li><a href="/helpline"><i class="fas fa-phone-alt"></i> Helpline</a></li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    <li><a href="/register"><i class="fas fa-user-plus"></i> Signup</a></li>
                    <li><a href="/login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
                    <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Results Header -->
    <div class="container" style="margin-top: 40px;">
        <div class="glass-panel" style="text-align: center; margin-bottom: 30px; padding: 20px;">
            <h3 style="margin: 0; font-weight: 300;">
                <span style="color: #4facfe; font-weight: 600;"><%= source %></span> 
                <i class="fas fa-arrow-right" style="margin: 0 15px; color: rgba(255,255,255,0.5); font-size: 18px;"></i> 
                <span style="color: #4facfe; font-weight: 600;"><%= destination %></span>
            </h3>
            <p style="margin-top: 10px; color: rgba(255,255,255,0.7); font-size: 16px;">
                <i class="far fa-calendar-alt"></i> Journey Date: <%= date %>
            </p>
        </div>

        <h2 class="page-title" style="margin-bottom: 25px;"><i class="fas fa-list-ul"></i> Available Trains</h2>

        <% var i = 0; %>
        
        <% if(trains.length === 0) { %>
            <div class="glass-panel" style="text-align: center; padding: 50px;">
                <i class="fas fa-exclamation-circle" style="font-size: 50px; color: #ff0844; margin-bottom: 20px;"></i>
                <h3>No Trains Found</h3>
                <p style="color: rgba(255,255,255,0.7);">We couldn't find any trains running on this route for the selected date.</p>
                <a href="/" class="btn glass-btn" style="margin-top: 20px;">Modify Search</a>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table glass-table">
                    <thead>
                        <tr>
                            <th style="text-align: center;">#</th>
                            <th>Train No.</th>
                            <th>Train Name</th>
                            <th>Duration</th>
                            <th>Departure</th>
                            <th>Fare</th>
                            <th style="text-align: center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% trains.forEach(function(train){ %>
                            <% train.train_details.forEach(function(f){ %>
                                <tr>
                                    <td style="text-align: center; font-weight: 600; color: rgba(255,255,255,0.5);"><%= ++i %></td>
                                    <td style="font-weight: 600; letter-spacing: 1px;"><%= f.number %></td>
                                    <td><i class="fas fa-subway" style="color: #4facfe; margin-right: 8px;"></i> <%= f.name %></td>
                                    <td><i class="far fa-clock" style="color: #00f2fe; margin-right: 8px;"></i> <%= f.travel_time %></td>
                                    <td style="font-weight: 600;"><%= f.start_time %></td>
                                    <td style="color: #00f2fe; font-weight: 600; font-size: 16px;"><i class="fas fa-rupee-sign"></i> <%= f.fare %></td>
                                    <td style="text-align: center;">
                                        <a href="/train/show/check_availability/<%=train._id%>/<%=date%>" class="btn glass-btn-outline" style="padding: 5px 15px; font-size: 13px;">
                                            Select
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>

</body>
</html>